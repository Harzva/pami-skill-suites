{
  "schema_version": "1.0",
  "family": "elsevier",
  "version": "0.5.0",
  "default_chain": [
    "elsevier-skill-suite",
    "elsevier-journal-router",
    "elsevier-component-router",
    "elsevier-submission-router"
  ],
  "selection_policy": [
    "Select one publisher-family router first.",
    "Select at most one primary journal adapter unless the task asks for comparison.",
    "Select only components mentioned or logically coupled to mentioned components.",
    "Route rights, agreements, licenses, open access, policies, and submission portal items to submission router plus official-source audit.",
    "When official instructions differ from repository guidance, official instructions win."
  ],
  "coupled_routes": [
    {
      "trigger_components": [
        "figure",
        "table",
        "caption"
      ],
      "recommended_chain": [
        "elsevier-figure",
        "elsevier-table",
        "elsevier-caption"
      ]
    },
    {
      "trigger_components": [
        "related-work",
        "contribution-positioning",
        "reference-integrity"
      ],
      "recommended_chain": [
        "elsevier-related-work",
        "elsevier-citation"
      ]
    },
    {
      "trigger_components": [
        "experiment",
        "ablation-study",
        "statistical-reporting",
        "results-reporting"
      ],
      "recommended_chain": [
        "elsevier-method-experiment"
      ]
    },
    {
      "trigger_components": [
        "author-agreement",
        "declarations"
      ],
      "recommended_chain": [
        "elsevier-author-agreement",
        "elsevier-official-source-audit"
      ]
    }
  ],
  "official_source_policy": [
    "https://www.elsevier.com/researcher/author/policies-and-guidelines/latex-instructions",
    "https://www.elsevier.com/researcher/author/tools-and-resources/highlights",
    "https://www.elsevier.com/researcher/author/tools-and-resources/graphical-abstract",
    "https://www.elsevier.com/about/policies-and-standards/copyright"
  ]
}
